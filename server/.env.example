PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/lms_db

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_password
EMAIL_FROM=noreply@yourlibrary.com

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_PRIVATE_KEY=your-firebase-private-key

# Frontend URL
CLIENT_URL=http://localhost:5173

# File Upload
MAX_FILE_SIZE=50000000
UPLOAD_PATH=./uploads

# ── S3 / Storage (Feature: Digital PDF Sales + Signed URLs) ──────────────────
# Set USE_LOCAL_STORAGE=true for development (stores files in ./uploads/s3-sim/)
USE_LOCAL_STORAGE=true
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1
AWS_BUCKET_NAME=lms-books
SIGNED_URL_EXPIRES_SECONDS=300

# Max downloads per purchase (default 5)
MAX_DOWNLOADS=5
